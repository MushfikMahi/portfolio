# ── Contact Form (Resend) ─────────────────────────────────────────────────────
# 1. Sign up free at https://resend.com
# 2. Create an API key (Sending → API Keys)
# 3. Copy it here, then rename this file to .env.local
#
# FREE TIER NOTE:
# Until you add & verify your own domain in Resend, the "from" address
# in app/api/contact/route.ts must stay as: onboarding@resend.dev
# (Resend's sandbox sender). Emails will still arrive at your Gmail.
# Once your domain is verified, change "from" to: portfolio@yourdomain.com

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
